<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar una película</title>
    <link rel="stylesheet" href="/main.css">
</head>

<body>
    <div class="container-movies">
        <h1>Editar una película</h1>
        <form action="/sendEditMovie" method="POST" novalidate>
            <div>
                <input type="hidden" id="id_movie" name="id_movie" value="<%=id_movie%>" required>
            </div>

            <div class="input-group">
                <input type="text" id="title" name="title" value="<%=title%>" required>
            </div>

            <div class="input-group">
                <input type="text" id="director" name="director" value="<%=director%>" required>
            </div>

            <div class="input-group">
                <input type="number" id="year_movie" name="year_movie" value="<%=year_movie%>" required>
            </div>

            <div class="input-group">
                <input type="text" id="genre" name="genre" value="<%=genre_id%>" required>
            </div>

            <div class="input-group">
                <input type="text" id="duration" name="duration" value="<%=duration%>" required>
            </div>

            <div class="input-group">
                <textarea id="synopsis" name="synopsis" class="input-synopsys" required><%=synopsis%></textarea>
            </div>

            <div class="input-group">
                <input type="file" id="image_url" name="image_url" value="<%=image_url%>"required>
            </div>

            <button type="submit" class="btn">Editar película</button>
        </form>
    </div>
</body>

</html>